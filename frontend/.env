# ══════════════════════════════════════════════
# BookWise Frontend — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════

# Backend API URL
# Development: leave empty (Vite proxy handles /api → localhost:8000)
# Production: set to your Vercel backend URL
VITE_API_URL=

# Google OAuth Client ID
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Must match GOOGLE_CLIENT_ID in backend .env
VITE_GOOGLE_CLIENT_ID=44512109806-f5hcda7nrq3c1uhr4jaa7hvaavkkoqjk.apps.googleusercontent.com
